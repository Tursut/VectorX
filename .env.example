# Copy to `.env.local` for per-developer overrides (gitignored via *.local).
# Repo-wide defaults live in `.env`.

# Toggle online multiplayer UI (Play online button on StartScreen).
# Turn on to exercise the online flow during development.
VITE_ENABLE_ONLINE=false

# Origin of the Worker server. Dev default in code is `http://localhost:8787`
# which matches `npx wrangler dev --config server/wrangler.toml`. Override for
# a deployed preview/prod build:
# VITE_SERVER_URL=https://vectorx-server.your-subdomain.workers.dev
