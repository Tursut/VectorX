# Default env for local and production builds.
# Online multiplayer is gated behind this flag and stays off until Step 18.
# Preview builds (Step 18+) override to true via CI env; do not commit `true` here.
VITE_ENABLE_ONLINE=false

# Cloudflare Worker origin (HTTP). Defaults to `http://localhost:8787` in code
# (see src/config.js) when unset — matches `npx wrangler dev`. Step 18 sets
# this to the workers.dev subdomain at build time.
# VITE_SERVER_URL=http://localhost:8787
